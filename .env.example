# StudioX Claw Gateway — Environment Variables
# Copy to .env and fill in values

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/webhooks/telegram

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=       # optional: for guild-scoped commands during dev

# Firebase Admin (from Firebase Console → Project Settings → Service Accounts)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=

# Gateway
CLAW_GATEWAY_PORT=3001
CLAW_GATEWAY_HOST=http://localhost:3001
STUDIOX_APP_BASE_URL=https://sp-website-staging-new.vercel.app
APIMART_API_KEY=your_apimart_api_key_here

# Slack (Phase 5)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
